# Copy this file to ".env" (which is git-ignored) and fill in real values as we wire each tool.
# The brain reads keys from .env; never paste keys into chat or commit them.

# --- Customer / CRM ---
# GHL_API_KEY=
# GHL_LOCATION_ID=

# --- Revenue ---
# STRIPE_API_KEY=

# --- Comms / Calendar / Knowledge (Google Workspace) ---
# handled via the Google Workspace CLI auth, not a key here (set up later)

# --- Growth / research ---
# APIFY_TOKEN=

# --- LLM (for tasks the brain runs itself) ---
# OPENAI_API_KEY=
