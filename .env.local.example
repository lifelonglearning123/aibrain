# Copy this file to ".env.local" (git-ignored) and fill in values.

# --- Supabase ---
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Used by data sync + cron (later). NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI (AI drafting + insights) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# --- Access control (multi-tenant) ---
# Comma-separated owner emails (full access to all companies). Partners are added
# in-app on the Team page. If left blank AND no partners exist, everyone who signs
# in is treated as an owner (so nothing breaks until you configure it).
# OWNER_EMAILS=you@macaws.ai

# Which brand's GoHighLevel account sends system emails (partner invites + sign-in
# links). Defaults to "macaws"; falls back to any connected brand. Also settable
# in Settings → Access.
# EMAIL_SENDER_BRAND=macaws

# --- Scheduled learning (Vercel Cron) ---
# Set the SAME value in Vercel env; Vercel sends it as a Bearer token to /api/cron/learn.
# CRON_SECRET=

# --- Social: image generation ---
# HIGGSFIELD_API_KEY=     # images/carousels (Nano Banana Pro, etc.)
# HIGGSFIELD_MODEL=nano-banana-pro   # override the image model if needed
# HIGGSFIELD_VIDEO_MODEL=veo-3       # override the video model for AI clips

# --- Video assembly: Shotstack (stitch clips → MP4) ---
# SHOTSTACK_API_KEY=
# SHOTSTACK_ENV=production            # or: stage (sandbox)
# HIGGSFIELD_BASE_URL=               # override API host if it differs from api.higgsfield.ai
# BLOTATO_API_KEY=        # optional alt publisher (GHL is the default social rail)

# Social publishing uses your GoHighLevel tokens (GHL_TOKEN__<BRAND> above) —
# no separate key needed; the brand's GHL location must have socials connected.

# --- Facebook (Meta) Ads — ad spend → cost-per-lead & ROAS (per brand) ---
# A long-lived / system-user access token with ads_read on each brand's ad account.
# FACEBOOK_ADS_TOKEN__MACAWS=
# FACEBOOK_AD_ACCOUNT__MACAWS=            # act_XXXXXXXX (or just the number)
# FACEBOOK_ADS_TOKEN__ARTIFICIAL_IGNORANCE=
# FACEBOOK_AD_ACCOUNT__ARTIFICIAL_IGNORANCE=
# FACEBOOK_ADS_TOKEN__LEONARDO=
# FACEBOOK_AD_ACCOUNT__LEONARDO=
# FACEBOOK_API_VERSION=v21.0             # optional Graph API version override

# --- Apify (market & lead research, Marketing view) ---
# APIFY_TOKEN=
# APIFY_ACTOR_ID=compass~crawler-google-places   # which Apify actor to run for research

# --- Signal (voice platform) — read-only call data for self-learning ---
# SIGNAL_SUPABASE_URL=https://xxxx.supabase.co
# SIGNAL_SUPABASE_SERVICE_KEY=

# --- Phase 1+ connection secrets (added per account, one key per brand) ---
# STRIPE_KEY__MACAWS=
# STRIPE_KEY__ARTIFICIAL_IGNORANCE=
# STRIPE_KEY__LEONARDO=

# --- GoHighLevel (CRM) — Private Integration Token + location per brand ---
# (3 separate agencies → one token + location per brand; add more if a brand
#  has several sub-accounts). Create a Private Integration in each GHL location.
# GHL_TOKEN__MACAWS=
# GHL_LOCATION__MACAWS=
# GHL_TOKEN__ARTIFICIAL_IGNORANCE=
# GHL_LOCATION__ARTIFICIAL_IGNORANCE=
# GHL_TOKEN__LEONARDO=
# GHL_LOCATION__LEONARDO=
# Optional currency override per brand (defaults GBP): GHL_CURRENCY__MACAWS=GBP

# --- QuickBooks (accounting) — OAuth2, one company per brand ---
# From your Intuit developer app (https://developer.intuit.com):
# QUICKBOOKS_CLIENT_ID=
# QUICKBOOKS_CLIENT_SECRET=
# QUICKBOOKS_ENVIRONMENT=production          # or: sandbox
# QUICKBOOKS_REDIRECT_URI=http://localhost:3000/api/integrations/quickbooks/callback
#   (must EXACTLY match a Redirect URI registered in the Intuit app; use your
#    Vercel URL in production. Then connect each brand from Connected apps.)

# --- Xero (accounting) — OAuth2, for brands on Xero (e.g. Artificial Ignorance) ---
# From your Xero app (https://developer.xero.com/app/manage). Scopes needed:
# offline_access accounting.reports.read
# XERO_CLIENT_ID=
# XERO_CLIENT_SECRET=
# XERO_REDIRECT_URI=https://aibrain.macaws.ai/api/integrations/xero/callback
#   (must EXACTLY match a Redirect URI registered in the Xero app; then connect
#    each Xero brand from Connected apps.)
# Optional per-brand currency for accounting (defaults GBP):
# ACCOUNTING_CURRENCY__ARTIFICIAL_IGNORANCE=GBP

# --- Linked app: Goal Engine (retargeting) ---
# GOAL_ENGINE_URL=https://goal-engine.vercel.app
# GOAL_ENGINE_ENROLL_SECRET=   (the ENROLL_SECRET from your Goal Engine env)
